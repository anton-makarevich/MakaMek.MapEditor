<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sanet.MakaMek.MapEditor.ViewModels"
             xmlns:fragments="using:Sanet.MakaMek.Avalonia.Controls.Fragments"
             xmlns:extensions="clr-namespace:Sanet.MakaMek.Avalonia.Controls.Extensions;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:templatedControls="clr-namespace:Sanet.MakaMek.Avalonia.Controls.TemplatedControls;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:ff="clr-namespace:Avalonia.Markup.Xaml.MarkupExtensions;assembly=Avalonia.Markup.Xaml"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sanet.MakaMek.MapEditor.Views.NewMapView"
             x:CompileBindings="True"
             x:DataType="viewModels:NewMapViewModel">
    <Grid RowDefinitions="*,Auto" Margin="20">
        <templatedControls:HexagonBackground/>
        <ScrollViewer Grid.Row="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
            <fragments:MapConfigFragment DataContext="{Binding MapConfig}" />
        </ScrollViewer>

        <StackPanel Grid.Row="1" Classes="verticalSpaced">
            <Button Classes="primary main-menu" Content="{extensions:Localize 'NewMap_CreateMap'}"
                                HorizontalAlignment="Center"
                                Command="{Binding EditMapCommand}"/>
            <Button Content="{extensions:Localize 'NewMap_AboutButton'}"
                    Command="{Binding OpenAboutCommand}"
                    HorizontalAlignment="Center"
                    IsVisible="False"
                    Classes="secondary"/>
            
        </StackPanel>
    </Grid>
</UserControl>
