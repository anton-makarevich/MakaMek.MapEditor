<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sanet.MakaMek.MapEditor.ViewModels"
              xmlns:controls="clr-namespace:Sanet.MakaMek.Avalonia.Controls;assembly=Sanet.MakaMek.Avalonia.Controls"
              xmlns:templatedControls="clr-namespace:Sanet.MakaMek.Avalonia.Controls.TemplatedControls;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:extensions="clr-namespace:Sanet.MakaMek.Avalonia.Controls.Extensions;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:ff="clr-namespace:Avalonia.Markup.Xaml.MarkupExtensions;assembly=Avalonia.Markup.Xaml"
               xmlns:converters="clr-namespace:Sanet.MakaMek.MapEditor.Converters"
              xmlns:ctrl="clr-namespace:Sanet.MakaMek.MapEditor.Controls"
              mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sanet.MakaMek.MapEditor.Views.EditMapView"
             x:CompileBindings="True"
             x:DataType="viewModels:EditMapViewModel">
    <UserControl.Resources>
        <converters:StringToImageConverter x:Key="StringToImageConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>
    </UserControl.Styles>
    <Grid ColumnDefinitions="{ff:OnFormFactor Desktop='*,200', Mobile='*'}"
          RowDefinitions="{ff:OnFormFactor Desktop='*', Mobile='*,Auto'}">
        <controls:HexMap
            ContentClicked="MapCanvas_OnContentClicked"
            x:Name="MapCanvas"/>

        <ctrl:HexInfoOverlay x:Name="HexInfoOverlay"
                               IsVisible="{Binding IsHexInfoVisible}"
                               Margin="10"/>
        
        <!-- Floating toggle button (visible on mobile only) -->
        <Button Grid.Column="0"
                Grid.Row="0"
                IsVisible="{ff:OnFormFactor Desktop=False, Mobile=True}"
                Command="{Binding ToggleSettingsPanelCommand}"
                Content="{extensions:Localize 'EditMap_Settings'}"
                Classes="primary"
                Background="{StaticResource AccentBrush}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Padding="15,10"/>
        
        <Grid Grid.Column="{ff:OnFormFactor Desktop=1, Mobile=0}"
              Grid.Row="{ff:OnFormFactor Desktop=0, Mobile=1}"
              RowDefinitions="Auto,*,Auto" Background="{StaticResource SurfaceBrush}">
            <TextBlock Text="{extensions:Localize 'EditMap_Toolbox'}" Classes="h3" Margin="10" Foreground="{StaticResource TextLightBrush}" HorizontalAlignment="Center"/>

            <ListBox Grid.Row="1" ItemsSource="{Binding AvailableTools}" SelectedItem="{Binding SelectedTool}" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="{ff:OnFormFactor Desktop='Disabled', Mobile='Auto'}"
                     ScrollViewer.VerticalScrollBarVisibility="{ff:OnFormFactor Desktop='Auto', Mobile='Disabled'}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="{ff:OnFormFactor Desktop='Horizontal', Mobile='Vertical'}" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="85" Margin="4" HorizontalAlignment="Center">
                            <Image Source="{Binding ImagePath, Converter={StaticResource StringToImageConverter}}" Width="64" Height="64" IsVisible="{Binding HasImagePath}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextLightBrush}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="80"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ctrl:SettingsPanel Grid.Row="2" x:Name="SettingsPanelControl"
                                 IsVisible="{Binding IsSettingsPanelVisible}"/>
        </Grid>
    </Grid>
</UserControl>
