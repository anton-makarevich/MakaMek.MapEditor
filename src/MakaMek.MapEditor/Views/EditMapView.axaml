<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sanet.MakaMek.MapEditor.ViewModels"
              xmlns:controls="clr-namespace:Sanet.MakaMek.Avalonia.Controls;assembly=Sanet.MakaMek.Avalonia.Controls"
              xmlns:templatedControls="clr-namespace:Sanet.MakaMek.Avalonia.Controls.TemplatedControls;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:extensions="clr-namespace:Sanet.MakaMek.Avalonia.Controls.Extensions;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:ff="clr-namespace:Avalonia.Markup.Xaml.MarkupExtensions;assembly=Avalonia.Markup.Xaml"
             xmlns:converters="clr-namespace:Sanet.MakaMek.MapEditor.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sanet.MakaMek.MapEditor.Views.EditMapView"
             x:CompileBindings="True"
             x:DataType="viewModels:EditMapViewModel">
    <UserControl.Resources>
        <converters:StringToImageConverter x:Key="StringToImageConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>
    </UserControl.Styles>
    <Grid ColumnDefinitions="{ff:OnFormFactor Desktop='*,200', Mobile='*'}"
          RowDefinitions="{ff:OnFormFactor Desktop='*', Mobile='*,Auto'}">
        <controls:HexMap
            ContentClicked="MapCanvas_OnContentClicked"
            x:Name="MapCanvas"/>

        <Grid IsVisible="{Binding IsHexInfoVisible}"
              x:Name="HexInfoOverlay"
              Background="{StaticResource BackgroundBrush}"
              RowDefinitions="Auto,*"
              HorizontalAlignment="Left" 
              VerticalAlignment="Top" 
              ZIndex="100"
              MinWidth="150"
              Margin="10">
                <Grid Grid.Row="0"
                      Background="{StaticResource SecondaryBrush}"
                      Height="40" ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding HexViewModel.Coordinates}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{StaticResource HighlightLightBrush}"/>
                    <templatedControls:ActionButton
                        Grid.Column="1"
                        Command="{Binding CloseHexInfoCommand}"
                        IconData="{StaticResource CloseIcon}"
                        Background="Transparent"/>
                </Grid>
                <StackPanel Grid.Row="1" Spacing="4">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel 
                        Orientation="Horizontal"
                        Spacing="5">
                        <TextBlock Text="{extensions:Localize 'EditMap_Elevation'}"
                                   Classes="bodyLarge" FontWeight="Bold" Foreground="{StaticResource TextLightBrush}"/>
                        <TextBlock Text="{Binding HexViewModel.Level}"
                                   Classes="bodySmall" Foreground="{StaticResource TextLightBrush}"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="▲" FontSize="10" Padding="4,0"
                            Command="{Binding RaiseLevelCommand}"
                            ToolTip.Tip="{extensions:Localize 'EditMap_RaiseLevel'}"
                            Classes="cardAction" Foreground="{StaticResource TextLightBrush}"/>
                    <Button Grid.Column="2" Content="▼" FontSize="10" Padding="4,0"
                            Command="{Binding LowerLevelCommand}"
                            ToolTip.Tip="{extensions:Localize 'EditMap_LowerLevel'}"
                            Classes="cardAction" Foreground="{StaticResource TextLightBrush}"/>
                </Grid>
                
                <TextBlock Text="{extensions:Localize 'EditMap_Terrains'}" Foreground="{StaticResource TextLightBrush}" Classes="bodySmall"/>
                <ItemsControl ItemsSource="{Binding HexViewModel.TerrainTypes}" Margin="10,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding }" Classes="bodySmall" Foreground="{StaticResource TextLightBrush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid ColumnDefinitions="*,Auto,Auto"
                      IsVisible="{Binding HexViewModel.IsWater}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{extensions:Localize 'EditMap_WaterDepth'}"
                                   Classes="bodySmall" Foreground="{StaticResource TextLightBrush}"/>
                        <TextBlock Text="{Binding HexViewModel.WaterDepth}"
                                   Classes="bodySmall" Foreground="{StaticResource TextLightBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="▲" FontSize="10" Padding="4,0"
                            Command="{Binding DecreaseWaterDepthCommand}"
                            ToolTip.Tip="{extensions:Localize 'EditMap_DecreaseWaterDepth'}"
                            Classes="cardAction" Foreground="{StaticResource TextLightBrush}"/>
                    <Button Grid.Column="2" Content="▼" FontSize="10" Padding="4,0"
                            Command="{Binding IncreaseWaterDepthCommand}"
                            ToolTip.Tip="{extensions:Localize 'EditMap_IncreaseWaterDepth'}"
                            Classes="cardAction" Foreground="{StaticResource TextLightBrush}"/>
                </Grid>
                </StackPanel>
            </Grid>
        
        <!-- Floating toggle button (visible on mobile only) -->
        <Button Grid.Column="0"
                Grid.Row="0"
                IsVisible="{ff:OnFormFactor Desktop=False, Mobile=True}"
                Command="{Binding ToggleSettingsPanelCommand}"
                Content="{extensions:Localize 'EditMap_Settings'}"
                Classes="primary"
                Background="{StaticResource AccentBrush}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Padding="15,10"/>
        
        <Grid Grid.Column="{ff:OnFormFactor Desktop=1, Mobile=0}"
              Grid.Row="{ff:OnFormFactor Desktop=0, Mobile=1}"
              RowDefinitions="Auto,*,Auto" Background="{StaticResource SurfaceBrush}">
            <TextBlock Text="{extensions:Localize 'EditMap_Toolbox'}" Classes="h3" Margin="10" Foreground="{StaticResource TextLightBrush}" HorizontalAlignment="Center"/>

            <ListBox Grid.Row="1" ItemsSource="{Binding AvailableTools}" SelectedItem="{Binding SelectedTool}" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="{ff:OnFormFactor Desktop='Disabled', Mobile='Auto'}"
                     ScrollViewer.VerticalScrollBarVisibility="{ff:OnFormFactor Desktop='Auto', Mobile='Disabled'}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="{ff:OnFormFactor Desktop='Horizontal', Mobile='Vertical'}" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="85" Margin="4" HorizontalAlignment="Center">
                            <Image Source="{Binding ImagePath, Converter={StaticResource StringToImageConverter}}" Width="64" Height="64" IsVisible="{Binding HasImagePath}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextLightBrush}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="80"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Spacing="10"
                        IsVisible="{Binding IsSettingsPanelVisible}">
                <StackPanel Margin="10" Spacing="10">
                    <TextBlock Text="{extensions:Localize 'BattleMap_Settings'}" Classes="h4" Foreground="{StaticResource TextLightBrush}"/>
                    <CheckBox Content="{extensions:Localize 'BattleMap_ShowLabels'}"
                              IsChecked="{Binding HexConfiguration.ShowLabels}"
                              Foreground="{StaticResource TextLightBrush}"/>
                    <CheckBox Content="{extensions:Localize 'BattleMap_ShowHexOutlines'}"
                              IsChecked="{Binding HexConfiguration.ShowOutline}"
                              Foreground="{StaticResource TextLightBrush}"/>
                </StackPanel>

                <StackPanel Margin="10" Spacing="10" VerticalAlignment="Bottom">
                    <Button Content="{extensions:Localize 'EditMap_ExportMap'}" Command="{Binding ExportMapCommand}" Classes="secondary" HorizontalAlignment="Stretch"/>
                    <Button Content="{extensions:Localize 'EditMap_ExportPdf'}" Click="OnExportPdfClicked" Classes="secondary" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
