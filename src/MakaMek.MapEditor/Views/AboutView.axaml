<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sanet.MakaMek.MapEditor.ViewModels"
             xmlns:extensions="clr-namespace:Sanet.MakaMek.Avalonia.Controls.Extensions;assembly=Sanet.MakaMek.Avalonia.Controls"
             xmlns:templatedControls="clr-namespace:Sanet.MakaMek.Avalonia.Controls.TemplatedControls;assembly=Sanet.MakaMek.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sanet.MakaMek.MapEditor.Views.AboutView"
             x:CompileBindings="True"
             x:DataType="viewModels:AboutViewModel">
    <Grid RowDefinitions="*,Auto" Margin="20">
        <templatedControls:HexagonBackground/>
        <ScrollViewer Grid.Row="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Center" Margin="0,20">
                <TextBlock Text="{extensions:Localize 'About_Title'}"
                           Classes="h1" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Version}"
                           Classes="bodySmall" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextLightBrush}"/>
                <TextBlock Text="{extensions:Localize 'About_Description'}"
                           Classes="body" TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="{extensions:Localize 'About_Attribution'}"
                           Classes="body" TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="{extensions:Localize 'About_FossStatement'}"
                           Classes="body" TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="{extensions:Localize 'About_TrademarkDisclaimer'}"
                           Classes="caption" TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,10">
                    <Button Content="{extensions:Localize 'About_GitHubButton'}"
                            Command="{Binding OpenGitHubCommand}"
                            Classes="secondary"
                            HorizontalAlignment="Stretch"/>
                    <Button Content="{extensions:Localize 'About_ContactButton'}"
                            Command="{Binding OpenContactCommand}"
                            Classes="secondary"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="1" Classes="primary main-menu"
                Content="{extensions:Localize 'About_CloseButton'}"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
