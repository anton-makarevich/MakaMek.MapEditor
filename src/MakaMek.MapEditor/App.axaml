<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:di="using:Microsoft.Extensions.DependencyInjection"
             x:Class="Sanet.MakaMek.MapEditor.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <ResourceDictionary>
            <di:ServiceCollection x:Key="ServiceCollection"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Sanet.MakaMek.Avalonia.Controls/Styles/Resources.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
             
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Sanet.MakaMek.Avalonia.Controls/Styles/Theme.axaml"/>
        <StyleInclude Source="avares://Sanet.MakaMek.MapEditor/Styles/StepperButton.axaml"/>
    </Application.Styles>
</Application>
